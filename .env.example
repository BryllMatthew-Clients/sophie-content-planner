# ============================================================
# SOPHIE CONTENT PLAN — ENVIRONMENT VARIABLES (EXAMPLE)
# ============================================================
# Copy this file to .env and fill in your real values.
# This file is safe to commit. Never commit .env itself.

# ── Server ──────────────────────────────────────────────────
# Render sets PORT automatically. FRONTEND_URL = your Vercel domain (for CORS).
PORT=3000
FRONTEND_URL=http://localhost:3000

# ── Anthropic (Claude API) ──────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Brave Search API ────────────────────────────────────────
# Get from: https://api.search.brave.com/app/keys
# Free tier: 2,000 queries/month
BRAVE_API_KEY=

# ── Reddit API ──────────────────────────────────────────────
# Create a "script" app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=SophieContentBot/1.0 by your_reddit_username

# ── Output Directory ────────────────────────────────────────
OUTPUT_DIR=./output

# ── Serper.dev (Backup Search) ──────────────────────────────
# Get from: https://serper.dev — first 2,500 queries free
SERPER_API_KEY=

# ── v2: Airtable Content Calendar ───────────────────────────
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Content Calendar

# ── v2: Notion (Alternative Calendar) ───────────────────────
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ── v2: YouTube Data API ────────────────────────────────────
YOUTUBE_API_KEY=
